# Copie este arquivo para ".env" e ajuste os valores antes de rodar o servidor.

# Texto secreto usado para assinar os tokens de login. Troque por qualquer
# frase aleatória e longa — não precisa decorar, só não pode ficar vazio.
JWT_SECRET=troque-isso-por-um-texto-aleatorio-bem-grande

# Porta em que o servidor vai rodar localmente.
PORT=3001
